{
  "name": "@bugsnag/plugin-stackframe-path-normaliser",
  "version": "8.9.0",
    "type": "module",
  "main": "./dist/cjs/path-normaliser.js",
  "module": "./dist/esm/path-normaliser.js",
  "types": "./dist/cjs/path-normaliser.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/path-normaliser.d.ts",
        "default": "./dist/esm/path-normaliser.js"
      },
      "require": {
        "types": "./dist/cjs/network-breadcrumbs.d.ts",
        "default": "./dist/cjs/path-normaliser.js"
      }
    }
  },
  "description": "@bugsnag/js plugin to normalise file paths in stackframes",
  "homepage": "https://www.bugsnag.com/",
  "repository": {
    "type": "git",
    "url": "git@github.com:bugsnag/bugsnag-js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "author": "Bugsnag",
  "license": "MIT",
  "peerDependencies": {
    "@bugsnag/core": "^8.0.0"
  },
  "devDependencies": {
    "@bugsnag/core": "^8.9.0"
  },
   "scripts": {
    "clean": "rm -fr dist",
    "build": "rollup --config rollup.config.mjs",
    "test:types": "tsc -p tsconfig.json"
  }
}

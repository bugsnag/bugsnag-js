{
  "name": "@bugsnag/browser",
  "version": "8.8.1",
  "main": "dist/index-cjs.js",
  "module": "dist/index-es.mjs",
  "types": "dist/types/index-cjs.d.cts",
  "browser": "./dist/bugsnag.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": {
        "import": "./dist/types/index-es.d.mts",
        "require": "./dist/types/index-cjs.d.cts"
      },
      "import": "./dist/index-es.mjs",
      "require": "./dist/index-cjs.js"
    }
  },
  "description": "Bugsnag error reporter for browser JavaScript",
  "homepage": "https://www.bugsnag.com/",
  "repository": {
    "type": "git",
    "url": "git@github.com:bugsnag/bugsnag-js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "size": "../../bin/size dist/bugsnag.min.js",
    "clean": "rm -fr dist && mkdir dist",
    "prebuild": "npm run clean",
    "build": "rollup --config rollup.config.mjs",
    "cdn-upload": "../../bin/cdn-upload dist/*"
  },
  "author": "Bugsnag",
  "license": "MIT",
  "devDependencies": {
    "@bugsnag/delivery-xml-http-request": "^8.8.0",
    "@bugsnag/plugin-app-duration": "^8.8.0",
    "@bugsnag/plugin-browser-context": "^8.8.0",
    "@bugsnag/plugin-browser-device": "^8.8.0",
    "@bugsnag/plugin-browser-request": "^8.8.0",
    "@bugsnag/plugin-browser-session": "^8.8.0",
    "@bugsnag/plugin-client-ip": "^8.8.0",
    "@bugsnag/plugin-console-breadcrumbs": "^8.8.0",
    "@bugsnag/plugin-inline-script-content": "^8.8.0",
    "@bugsnag/plugin-interaction-breadcrumbs": "^8.8.0",
    "@bugsnag/plugin-navigation-breadcrumbs": "^8.8.0",
    "@bugsnag/plugin-network-breadcrumbs": "^8.8.1",
    "@bugsnag/plugin-simple-throttle": "^8.8.0",
    "@bugsnag/plugin-strip-query-string": "^8.8.0",
    "@bugsnag/plugin-window-onerror": "^8.8.0",
    "@bugsnag/plugin-window-unhandled-rejection": "^8.8.0"
  },
  "dependencies": {
    "@bugsnag/core": "^8.8.0"
  }
}

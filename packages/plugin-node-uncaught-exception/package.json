{
  "name": "@bugsnag/plugin-node-uncaught-exception",
  "version": "8.9.0",
  "type": "module",
  "main": "./dist/cjs/uncaught-exception.js",
  "module": "./dist/esm/uncaught-exception.js",
  "types": "./dist/cjs/uncaught-exception.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/uncaught-exception.d.ts",
        "default": "./dist/esm/uncaught-exception.js"
      },
      "require": {
        "types": "./dist/cjs/uncaught-exception.d.ts",
        "default": "./dist/cjs/uncaught-exception.js"
      }
    }
  },
  "description": "@bugsnag/js plugin to capture and report uncaught exceptions",
  "homepage": "https://www.bugsnag.com/",
  "repository": {
    "type": "git",
    "url": "git@github.com:bugsnag/bugsnag-js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -fr dist",
    "prebuild": "npm run clean",
    "build": "rollup --config rollup.config.mjs",
    "test:types": "tsc -p tsconfig.json"
  },
  "author": "Bugsnag",
  "license": "MIT",
  "devDependencies": {
    "@bugsnag/core": "^8.9.0"
  },
  "peerDependencies": {
    "@bugsnag/core": "^8.0.0"
  }
}

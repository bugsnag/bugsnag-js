{
  "name": "@bugsnag/plugin-network-breadcrumbs",
  "type": "module",
  "main": "./dist/cjs/network-breadcrumbs.js",
  "module": "./dist/esm/network-breadcrumbs.js",
  "types": "./dist/cjs/network-breadcrumbs.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/network-breadcrumbs.d.ts",
        "default": "./dist/esm/network-breadcrumbs.js"
      },
      "require": {
        "types": "./dist/cjs/network-breadcrumbs.d.ts",
        "default": "./dist/cjs/network-breadcrumbs.js"
      }
    }
  },
  "version": "8.9.0",
  "description": "@bugsnag/js plugin to record browser requests as breadcrumbs",
  "homepage": "https://www.bugsnag.com/",
  "repository": {
    "type": "git",
    "url": "git@github.com:bugsnag/bugsnag-js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "author": "Bugsnag",
  "license": "MIT",
  "devDependencies": {
    "@bugsnag/core": "^8.9.0"
  },
  "dependencies": {
    "@bugsnag/request-tracker": "^8.9.0"
  },
  "peerDependencies": {
    "@bugsnag/core": "^8.0.0"
  },
   "scripts": {
    "clean": "rm -fr dist",
    "prebuild": "npm run clean",
    "build": "rollup --config rollup.config.mjs"
  }
}

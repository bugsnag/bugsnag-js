{
  "name": "@bugsnag/delivery-xml-http-request",
  "main": "./dist/cjs/delivery.js",
  "module": "./dist/esm/delivery.js",
  "types": "./dist/cjs/delivery.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/delivery.d.ts",
        "default": "./dist/esm/delivery.js"
      },
      "require": {
        "types": "./dist/cjs/delivery.d.ts",
        "default": "./dist/cjs/delivery.js"
      }
    }
  },
  "version": "8.9.0",
  "description": "@bugsnag/js delivery mechanism for most browsers",
  "homepage": "https://www.bugsnag.com/",
  "repository": {
    "type": "git",
    "url": "git@github.com:bugsnag/bugsnag-js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "author": "Bugsnag",
  "license": "MIT",
  "scripts": {
    "clean": "rm -fr dist",
    "prebuild": "npm run clean",
    "build": "rollup --config rollup.config.mjs"
  },
  "devDependencies": {
    "@bugsnag/core": "^8.9.0"
  },
  "dependencies": {
    "@bugsnag/json-payload": "^8.4.0"
  }
}

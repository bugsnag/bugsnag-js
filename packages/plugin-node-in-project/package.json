{
  "name": "@bugsnag/plugin-node-in-project",
  "version": "8.9.0",
  "type": "module",
  "main": "./dist/cjs/in-project.js",
  "module": "./dist/esm/in-project.js",
  "types": "dist/types/in-project.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/in-project.d.ts",
        "default": "./dist/esm/in-project.js"
      },
      "require": {
        "types": "./dist/cjs/in-project.d.ts",
        "default": "./dist/cjs/in-project.js"
      }
    }
  },
  "description": "@bugsnag/js plugin to mark whether stackframes are 'in-project'",
  "homepage": "https://www.bugsnag.com/",
  "repository": {
    "type": "git",
    "url": "git@github.com:bugsnag/bugsnag-js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
   "scripts": {
    "build": "npm run build:npm",
    "build:npm": "rollup --config rollup.config.mjs",
    "clean": "rm -rf dist/*",
    "test:types": "tsc -p tsconfig.json"
  },
  "author": "Bugsnag",
  "license": "MIT",
  "dependencies": {
    "@bugsnag/path-normalizer": "^8.4.0"
  },
  "devDependencies": {
    "@bugsnag/core": "^8.9.0"
  }
}

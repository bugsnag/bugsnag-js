{
  "name": "@bugsnag/plugin-express",
  "version": "8.9.0",
  "type": "module",
  "main": "./dist/cjs/express.js",
  "module": "./dist/esm/express.js",
  "types": "./dist/cjs/express.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/express.d.ts",
        "default": "./dist/esm/express.js"
      },
      "require": {
        "types": "./dist/cjs/express.d.ts",
        "default": "./dist/cjs/express.js"
      }
    }
  },
  "description": "@bugsnag/js error handling middleware for Express (and Connect) web servers",
  "homepage": "https://www.bugsnag.com/",
  "repository": {
    "type": "git",
    "url": "git@github.com:bugsnag/bugsnag-js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "author": "Bugsnag",
  "license": "MIT",
  "peerDependencies": {
    "@bugsnag/core": "^8.2.0"
  },
  "devDependencies": {
    "@bugsnag/core": "^8.9.0",
    "@types/express": "4.17.13"
  },
  "scripts": {
    "clean": "rm -fr dist",
    "prebuild": "npm run clean",
    "build": "rollup --config rollup.config.mjs",
    "test:types": "tsc -p tsconfig.json"
  }
}

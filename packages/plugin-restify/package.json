{
  "name": "@bugsnag/plugin-restify",
  "version": "8.9.0",
  "main": "dist/restify.js",
  "types": "dist/types/restify.d.ts",
  "module": "./dist/esm/restify.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/restify.d.ts",
        "default": "./dist/esm/restify.js"
      },
      "require": {
        "types": "./dist/cjs/restify.d.ts",
        "default": "./dist/cjs/restify.js"
      }
    }
  },
  "description": "@bugsnag/js error handling middleware for Restify web servers",
  "homepage": "https://www.bugsnag.com/",
  "repository": {
    "type": "git",
    "url": "git@github.com:bugsnag/bugsnag-js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "author": "Bugsnag",
  "license": "MIT",
  "peerDependencies": {
    "@bugsnag/core": "^8.2.0"
  },
  "devDependencies": {
    "@bugsnag/core": "^8.9.0",
    "@types/restify": "^8.4.2"
  },
   "scripts": {
    "clean": "rm -fr dist",
    "build": "rollup --config rollup.config.mjs",
    "test:types": "tsc -p tsconfig.json"
  }
}

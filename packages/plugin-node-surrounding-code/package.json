{
  "name": "@bugsnag/plugin-node-surrounding-code",
  "version": "8.9.0",
  "type": "module",
  "main": "./dist/cjs/surrounding-code.js",
  "module": "./dist/esm/surrounding-code.js",
  "types": "./dist/cjs/surrounding-code.d.ts",
  "exports": {
      ".": {
      "import": {
        "types": "./dist/esm/surrounding-code.d.ts",
        "default": "./dist/esm/surrounding-code.js"
      },
      "require": {
        "types": "./dist/cjs/surrounding-code.d.ts",
        "default": "./dist/cjs/surrounding-code.js"
      }
    }
  },
  "description": "@bugsnag/js plugin to load surrounding code in Node stacktraces",
  "homepage": "https://www.bugsnag.com/",
  "repository": {
    "type": "git",
    "url": "git@github.com:bugsnag/bugsnag-js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "author": "Bugsnag",
  "license": "MIT",
  "dependencies": {
    "@types/byline": "^4.2.36",
    "@types/pump": "^1.1.3",
    "byline": "^5.0.0",
    "pump": "^3.0.0"
  },
  "devDependencies": {
    "@bugsnag/core": "^8.9.0"
  },
  "peerDependencies": {
    "@bugsnag/core": "^8.0.0"
  },
  "scripts": {
    "build": "rollup --config rollup.config.mjs",
    "clean": "rm -rf dist/*",
    "test:types": "tsc -p tsconfig.json"
  }
}
